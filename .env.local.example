# Public site URL (no trailing slash). Used to build auth callbacks + Stripe
# success/cancel URLs. In production set this to the canonical origin.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Supabase ----------------------------------------------------------------
# Project settings → API. The anon (publishable) key is safe in the browser; the
# service role key MUST stay server-side (it bypasses RLS).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Stripe ------------------------------------------------------------------
# Dashboard → Developers → API keys.
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Created when you wire up the /api/stripe/webhook endpoint (see README).
STRIPE_WEBHOOK_SECRET=
# Price ID for the one-time EZStemz license purchase (Products → your product
# → pricing).
STRIPE_PRICE_ID=

# --- GitHub Releases ---------------------------------------------------------
# owner/repo that hosts the signed DMG + Windows installer.
GITHUB_REPO=orange-groove/ez-stemz
# Required when releases are private. Fine-grained PAT with Contents: read on
# the repo above (or classic `repo` scope).
GITHUB_TOKEN=
